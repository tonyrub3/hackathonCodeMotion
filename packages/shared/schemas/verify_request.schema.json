{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifyRequest",
  "type": "object",
  "required": ["content"],
  "properties": {
    "input_type": {
      "type": "string",
      "enum": ["text", "url"],
      "default": "text"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50000
    },
    "language": {
      "type": "string",
      "default": "en"
    },
    "country": {
      "type": "string",
      "default": ""
    },
    "topic": {
      "type": "string",
      "default": ""
    },
    "mode": {
      "type": "string",
      "enum": ["live", "benchmark"],
      "default": "live"
    }
  }
}
