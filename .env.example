# Truth Engine – Environment Variables

# Server
TE_HOST=0.0.0.0
TE_PORT=8000
TE_DEBUG=true
TE_CORS_ORIGINS=http://localhost:3000

# Regolo / LLM
REGOLO_API_KEY=
REGOLO_BASE_URL=https://api.regolo.ai/v1
REGOLO_MODEL=Llama-3.3-70B-Instruct
REGOLO_QUERY_MODEL=Llama-3.3-70B-Instruct
REGOLO_CLAIM_MODEL=Llama-3.3-70B-Instruct
REGOLO_CROSSCHECK_MODEL=gpt-oss-120b
REGOLO_SCORING_MODEL=gpt-oss-120b
REGOLO_EMBEDDING_MODEL=gte-Qwen2

# Tavily
TAVILY_API_KEY=

# Pipeline
TE_MAX_CLAIMS=20
TE_MAX_EVIDENCE=10
TE_TIMEOUT=0
