# Truth Engine – Environment Variables
# Copy this to .env and fill in your values

# Server
TE_HOST=0.0.0.0
TE_PORT=8000
TE_DEBUG=true
TE_CORS_ORIGINS=http://localhost:3000

# Regolo / LLM
REGOLO_API_KEY=
REGOLO_BASE_URL=https://api.regolo.ai/v1
REGOLO_MODEL=regolo/regolo-default
REGOLO_EMBEDDING_MODEL=regolo/embedding-default

# Google Fact Check Tools API
GOOGLE_FACTCHECK_API_KEY=

# GDELT (public, no key needed)
GDELT_DOC_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_CONTEXT_API_URL=https://api.gdeltproject.org/api/v2/context/context

# FEVER benchmark
FEVER_DATA_DIR=data/fever

# Pipeline
TE_MAX_CLAIMS=20
TE_MAX_EVIDENCE=10
TE_TIMEOUT=30
